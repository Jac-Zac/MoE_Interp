# Environment variables for MoE interpretability project
# Copy this file to .env and customize for your system

# HuggingFace cache directories
# HF_HOME=/path/to/your/scratch/.huggingface/cache
# HF_HUB_CACHE=/path/to/your/scratch/.huggingface/cache/hub
# HF_DATASETS_CACHE=/path/to/your/scratch/.huggingface/datasets

# PyTorch cache directory  
# TORCH_HOME=/path/to/your/scratch/.torch

# HuggingFace API token (if needed for gated models)
# HF_TOKEN=your_token_here
