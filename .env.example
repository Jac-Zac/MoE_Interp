# Copy this file to .env and fill in your values.

# ========================
# HuggingFace token
# ========================
# Required if the model is gated (e.g. allenai/OLMoE-1B-7B-0924-Instruct)
HF_TOKEN=your_token_here

# ========================
# Project data
# ========================
DATA_DIR=./data

# ========================
# HuggingFace cache (optional)
# ========================
# Override default ~/.cache/huggingface locations — useful on HPC clusters
# Example:
# HF_HOME=/scratch/${USER}/.huggingface/cache
# HF_HUB_CACHE=/scratch/${USER}/.huggingface/cache/hub
# HF_DATASETS_CACHE=/scratch/${USER}/.huggingface/datasets

# ========================
# Torch cache (optional)
# ========================
# TORCH_HOME=/scratch/${USER}/.torch
