# Copy this file to .env and fill in your values.

# ========================
# HuggingFace token
# ========================
# Required if the model is gated (e.g. allenai/OLMoE-1B-7B-0924-Instruct)
HF_TOKEN=your_token_here

# ========================
# Project data
# ========================
DATA_DIR=./data

# ========================
# HuggingFace cache (optional)
# ========================
# Override default ~/.cache/huggingface locations — useful on HPC clusters
# HF_HOME=/path/to/huggingface
# HF_DATASETS_CACHE=/path/to/huggingface/datasets

# ========================
# Torch cache (optional)
# ========================
# TORCH_HOME=/path/to/torch_cache
